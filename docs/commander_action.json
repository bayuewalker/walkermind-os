    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}/merge": {
      "put": {
        "operationId": "mergePullRequest",
        "summary": "Merge a pull request (squash only)",
        "description": "Merges a PR into main using squash method. FORGE and SENTINEL NEVER call this. WARP⛳CMD auto-merges MINOR/STANDARD after all checks pass. MAJOR requires Mr. Walker explicit go — CMD executes merge only after CMD approval.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "commit_title": {
                    "type": "string",
                    "description": "Squash commit title"
                  },
                  "commit_message": {
                    "type": "string",
                    "description": "Squash commit body"
                  },
                  "sha": {
                    "type": "string",
                    "description": "REQUIRED: expected_head_sha — current head SHA of the PR branch. Prevents race condition. Get from getPullRequest.head.sha first."
                  },
                  "merge_method": {
                    "type": "string",
                    "enum": [
                      "squash"
                    ],
                    "default": "squash",
                    "description": "Always squash for clean history"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Merged"
          },
          "405": {
            "description": "Not mergeable — check conflicts and CI"
          },
          "409": {
            "description": "SHA mismatch — re-fetch head SHA and retry"
          }
        }
      }
    },
