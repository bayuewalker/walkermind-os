{
  "openapi": "3.1.0",
  "info": {
    "title": "Walker AI — GitHub Full Access",
    "description": "Full read/write/review access to walkermind-os repo. Read files, write files, manage branches, create and merge PRs, fetch PR details and file diffs, manage issues and labels. Note: warp-codx repo operations use the same GitHub API with repo path bayuewalker/warp-codx.",
    "version": "3.1.0"
  },
  "servers": [
    {
      "url": "https://api.github.com"
    }
  ],
  "paths": {
    "/repos/bayuewalker/walkermind-os/contents/{path}": {
      "get": {
        "operationId": "getRepoContents",
        "summary": "Read file or list directory from walkermind-os repo",
        "description": "If path is a file, returns base64-encoded content. If path is a directory, returns array of files. Use for AGENTS.md, PROJECT_STATE.md, reports/forge/, reports/sentinel/, reports/briefer/, docs/, etc.",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "File or directory path from repo root. Examples: AGENTS.md | projects/polymarket/polyquantbot/state/PROJECT_STATE.md | docs/CLAUDE.md"
          },
          {
            "name": "ref",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Branch name. Default: main"
          }
        ],
        "responses": {
          "200": {
            "description": "File content (base64) or directory listing (array)"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "operationId": "writeRepoFile",
        "summary": "Create or update a file in walkermind-os repo",
        "description": "Creates a new file or updates existing file. Content must be base64-encoded. Requires sha when updating existing file — get SHA from getRepoContents first.",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Full file path from repo root. Example: projects/polymarket/polyquantbot/reports/forge/fix-signal-filter.md"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "message",
                  "content"
                ],
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "Commit message. Example: forge: add signal filter report"
                  },
                  "content": {
                    "type": "string",
                    "description": "Base64-encoded file content"
                  },
                  "sha": {
                    "type": "string",
                    "description": "Required when UPDATING existing file. Get SHA from getRepoContents first."
                  },
                  "branch": {
                    "type": "string",
                    "description": "Target branch. Default: main"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File updated successfully"
          },
          "201": {
            "description": "File created successfully"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/git/refs": {
      "post": {
        "operationId": "createBranch",
        "summary": "Create a new branch in walkermind-os repo",
        "description": "Creates a new branch from a base SHA. Always use WARP/{FEATURE} format per AGENTS.md. Get base SHA from getRepoBranch first.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "ref",
                  "sha"
                ],
                "properties": {
                  "ref": {
                    "type": "string",
                    "description": "New branch ref. Format: refs/heads/WARP/{FEATURE-SLUG}. Example: refs/heads/WARP/FIX-SIGNAL-FILTER"
                  },
                  "sha": {
                    "type": "string",
                    "description": "SHA of the base commit (latest main). Get from getRepoBranch."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Branch created"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/git/refs/heads/{branch}": {
      "delete": {
        "operationId": "deleteBranch",
        "summary": "Delete a branch after merge",
        "description": "Deletes a branch ref. Use after PR is merged to keep repo clean. Never delete main.",
        "parameters": [
          {
            "name": "branch",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Branch name to delete. Example: WARP/FIX-SIGNAL-FILTER"
          }
        ],
        "responses": {
          "204": {
            "description": "Branch deleted"
          },
          "422": {
            "description": "Branch cannot be deleted — may be protected"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/git/ref/heads/{branch}": {
      "get": {
        "operationId": "getRepoBranch",
        "summary": "Get branch info including latest commit SHA",
        "description": "Use to get the latest commit SHA before creating a new branch.",
        "parameters": [
          {
            "name": "branch",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Branch name. Example: main"
          }
        ],
        "responses": {
          "200": {
            "description": "Branch info with latest commit SHA"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/branches": {
      "get": {
        "operationId": "listBranches",
        "summary": "List all branches in walkermind-os repo",
        "description": "Returns all branches. Use to check open WARP/* branches and verify no orphaned branches exist post-merge.",
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of branches with name and commit SHA"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues": {
      "get": {
        "operationId": "listIssues",
        "summary": "List issues in walkermind-os repo",
        "description": "Returns open or all issues. Use to check active WARP task queue. Filter by label to get only warp/warp-sentinel issues.",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "closed",
                "all"
              ],
              "default": "open"
            }
          },
          {
            "name": "labels",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated label names to filter. Example: warp,forge-task"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of issues with number, title, labels, state, assignees"
          }
        }
      },
      "post": {
        "operationId": "createIssue",
        "summary": "Create a new issue in walkermind-os repo",
        "description": "Creates a GitHub issue. Use to create WARP•FORGE tasks, WARP•SENTINEL tasks, or any tracked work item. Issue body should follow WARP•FORGE TASK template from COMMANDER.md.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Issue title. Example: WARP•FORGE TASK: Fix signal filter edge case"
                  },
                  "body": {
                    "type": "string",
                    "description": "Issue body. Use WARP•FORGE TASK template from COMMANDER.md. No triple backtick nesting in task body."
                  },
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Label names. Examples: [\"warp\"], [\"warp-sentinel\"], [\"forge-task\", \"major\"]"
                  },
                  "assignees": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "GitHub usernames to assign. Example: [\"baayuewalker\"]"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Issue created — returns issue number and URL"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}": {
      "get": {
        "operationId": "getIssue",
        "summary": "Get a single issue by number",
        "description": "Returns full issue details: title, body, labels, assignees, state, comments count. Use to read WARP task details before executing.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Issue number"
          }
        ],
        "responses": {
          "200": {
            "description": "Full issue object"
          }
        }
      },
      "patch": {
        "operationId": "updateIssue",
        "summary": "Update or close an issue",
        "description": "Update issue state, title, body, labels, or assignees. To CLOSE: set state to 'closed'. To REOPEN: set state to 'open'. Use to close issues after corresponding PR is merged.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Issue number"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "state": {
                    "type": "string",
                    "enum": [
                      "open",
                      "closed"
                    ],
                    "description": "Set to 'closed' to close issue after PR merge"
                  },
                  "title": {
                    "type": "string",
                    "description": "Updated title (optional)"
                  },
                  "body": {
                    "type": "string",
                    "description": "Updated body (optional)"
                  },
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Replace all labels with this array"
                  },
                  "state_reason": {
                    "type": "string",
                    "enum": [
                      "completed",
                      "not_planned",
                      "reopened"
                    ],
                    "description": "Reason for closing. Use 'not_planned' for stale/cancelled issues, 'completed' for done tasks. Only valid when state='closed'."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Issue updated"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}/comments": {
      "post": {
        "operationId": "addIssueComment",
        "summary": "Add a comment to an issue or PR",
        "description": "Adds a comment. For PRs use PR number (GitHub uses issues endpoint for PR comments too). Use to post SENTINEL verdict, FORGE execution summary, or COMMANDER QC notes.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Issue or PR number"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "body"
                ],
                "properties": {
                  "body": {
                    "type": "string",
                    "description": "Comment text. Use markdown."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Comment added"
          }
        }
      },
      "get": {
        "operationId": "getIssueComments",
        "summary": "Get all comments on an issue or PR",
        "description": "Returns all comments including bot review summaries. Use to read full review context.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of comments with user, body, created_at"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}/labels": {
      "post": {
        "operationId": "addIssueLabel",
        "summary": "Add labels to an issue or PR",
        "description": "Add one or more labels. Use to tag issues with warp, warp-sentinel, forge-task, major, standard, minor, ready-for-merge, on-hold, needs-fix.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "labels"
                ],
                "properties": {
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Label names. Examples: [\"warp\"], [\"warp-sentinel\"], [\"ready-for-merge\"]"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Labels added"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}/assignees": {
      "post": {
        "operationId": "addAssignees",
        "summary": "Add assignees to an issue or PR",
        "description": "Assign GitHub users to an issue or PR.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "assignees"
                ],
                "properties": {
                  "assignees": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "GitHub usernames. Example: [\"bayuewalker\"]"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Assignees added"
          }
        }
      },
      "delete": {
        "operationId": "removeAssignees",
        "summary": "Remove assignees from an issue or PR",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "assignees"
                ],
                "properties": {
                  "assignees": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assignees removed"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/labels": {
      "get": {
        "operationId": "listRepoLabels",
        "summary": "List all labels in walkermind-os repo",
        "description": "Returns all available labels. Use to verify label names before applying to issues or PRs.",
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of labels with name, color, description"
          }
        }
      },
      "post": {
        "operationId": "createRepoLabel",
        "summary": "Create a new label in walkermind-os repo",
        "description": "Creates a new label. Use to create WARP standard labels: warp, warp-sentinel, forge-task, major, standard, minor, ready-for-merge, on-hold, needs-fix.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Label name. Example: warp-sentinel"
                  },
                  "color": {
                    "type": "string",
                    "description": "Hex color without #. Example: e4e669 (yellow), d93f0b (red), 0075ca (blue)"
                  },
                  "description": {
                    "type": "string",
                    "description": "Label description. Example: Triggers WARP•SENTINEL validation routine"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Label created"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls": {
      "get": {
        "operationId": "listPullRequests",
        "summary": "List pull requests in walkermind-os repo",
        "description": "Returns open or all PRs. Use to check WARP/* PR status and review results.",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "closed",
                "all"
              ],
              "default": "open"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of pull requests"
          }
        }
      },
      "post": {
        "operationId": "createPullRequest",
        "summary": "Create a pull request",
        "description": "Opens a new PR from a WARP/* branch to main. Include task summary, files changed, report path, validation tier, claim level in body.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "head",
                  "base"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "PR title. Example: WARP/FIX-SIGNAL-FILTER: fix edge case in signal dedup"
                  },
                  "head": {
                    "type": "string",
                    "description": "Source branch. Example: WARP/FIX-SIGNAL-FILTER"
                  },
                  "base": {
                    "type": "string",
                    "description": "Target branch. Always: main"
                  },
                  "body": {
                    "type": "string",
                    "description": "PR description. Include: scope, files changed, report path, validation tier, claim level."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "PR created"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}": {
      "patch": {
        "operationId": "updatePullRequest",
        "summary": "Update or close a pull request",
        "description": "Update PR state, title, or description. To CLOSE: set state to 'closed'. To REOPEN: set state to 'open'.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "state": {
                    "type": "string",
                    "enum": [
                      "open",
                      "closed"
                    ]
                  },
                  "title": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PR updated"
          },
          "422": {
            "description": "Validation error"
          }
        }
      },
      "get": {
        "operationId": "getPullRequest",
        "summary": "Get a single pull request by number",
        "description": "Returns full PR object including: number, title, body, state, head (branch, sha), base, mergeable, mergeable_state, merged, merged_at, user. Use to check mergeable_state before attempting merge and to verify head SHA matches expected.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "PR number"
          }
        ],
        "responses": {
          "200": {
            "description": "Full PR object with mergeable, mergeable_state, head.sha, state, merged fields"
          },
          "404": {
            "description": "PR not found"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}/merge": {
      "put": {
        "operationId": "mergePullRequest",
        "summary": "Merge a pull request",
        "description": "Merges a PR into main using squash method (preferred for clean history). WARP•FORGE and WARP•SENTINEL NEVER call this. WARP🔹CMD auto-merges MINOR and STANDARD tier PRs after all checks pass. MAJOR tier PRs require Mr. Walker explicit approval — WARP🔹CMD executes merge only after CMD go.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "commit_title": {
                    "type": "string",
                    "description": "Merge commit title"
                  },
                  "merge_method": {
                    "type": "string",
                    "enum": [
                      "merge",
                      "squash",
                      "rebase"
                    ],
                    "default": "squash"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PR merged successfully"
          },
          "405": {
            "description": "PR not mergeable — check review status and conflicts"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}/files": {
      "get": {
        "operationId": "getPRFiles",
        "summary": "Get list of files changed in a PR",
        "description": "Returns all files with status (added/modified/removed), additions, deletions, and patch diff. Use to verify scope hygiene — only expected files were touched.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of changed files with filename, status, additions, deletions, patch"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}/reviews": {
      "get": {
        "operationId": "getPRReviews",
        "summary": "Get all review results for a PR",
        "description": "Returns reviews from all bots and reviewers. Shows reviewer name, state (APPROVED/CHANGES_REQUESTED/COMMENTED), and review body. Use before merge decision.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of reviews with reviewer, state, submitted_at, body"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}/comments": {
      "get": {
        "operationId": "getPRInlineComments",
        "summary": "Get inline review comments on a PR diff",
