{
  "openapi": "3.1.0",
  "info": {
    "title": "WARP◆CMD — GitHub Full Access",
    "description": "Full read/write/review access to walkermind-os AND warp-codx repos. walkermind-os: bayuewalker/walkermind-os. warp-codx: bayuewalker/warp-codx. All gate commits must include author/committer: {name: 'warp-gate[bot]', email: 'warp-gate[bot]@users.noreply.github.com'}.",
    "version": "3.3.0"
  },
  "servers": [
    {
      "url": "https://api.github.com"
    }
  ],
  "paths": {
    "/repos/bayuewalker/walkermind-os/contents/{path}": {
      "get": {
        "operationId": "getRepoContents",
        "summary": "Read file or directory from walkermind-os",
        "description": "Returns base64-encoded content for files, or array for directories. Use for AGENTS.md, PROJECT_STATE.md, WORKTODO.md, CHANGELOG.md, reports/, docs/.",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "File path from repo root. Example: AGENTS.md"
          },
          {
            "name": "ref",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Branch name. Default: main"
          }
        ],
        "responses": {
          "200": {
            "description": "File content (base64) or directory listing"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "operationId": "writeRepoFile",
        "summary": "Create or update a file in walkermind-os",
        "description": "Content must be base64-encoded. Requires sha when updating. Always include author+committer as warp-gate[bot].",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "message",
                  "content"
                ],
                "properties": {
                  "message": {
                    "type": "string"
                  },
                  "content": {
                    "type": "string",
                    "description": "Base64-encoded file content"
                  },
                  "sha": {
                    "type": "string",
                    "description": "Required when updating. Get from getRepoContents."
                  },
                  "branch": {
                    "type": "string",
                    "default": "main"
                  },
                  "author": {
                    "type": "object",
                    "description": "Always: {name:'warp-gate[bot]',email:'warp-gate[bot]@users.noreply.github.com'}"
                  },
                  "committer": {
                    "type": "object",
                    "description": "Mirror author field"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/repos/bayuewalker/warp-codx/contents/{path}": {
      "get": {
        "operationId": "getWarpCodxContents",
        "summary": "Read file or directory from warp-codx",
        "description": "Same as getRepoContents but for warp-codx. Use for CHANGELOG.md, docs/, src/.",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ref",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Branch name. Default: main"
          }
        ],
        "responses": {
          "200": {
            "description": "File content or directory listing"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "operationId": "writeWarpCodxFile",
        "summary": "Create or update a file in warp-codx",
        "description": "Content must be base64-encoded. Requires sha when updating. Include warp-gate[bot] author/committer.",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "message",
                  "content"
                ],
                "properties": {
                  "message": {
                    "type": "string"
                  },
                  "content": {
                    "type": "string"
                  },
                  "sha": {
                    "type": "string"
                  },
                  "branch": {
                    "type": "string",
                    "default": "main"
                  },
                  "author": {
                    "type": "object"
                  },
                  "committer": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/git/refs": {
      "post": {
        "operationId": "createBranch",
        "summary": "Create a new branch in walkermind-os",
        "description": "Always use WARP/{FEATURE} uppercase hyphen format. Get base SHA from getRepoBranch first.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "ref",
                  "sha"
                ],
                "properties": {
                  "ref": {
                    "type": "string",
                    "description": "Format: refs/heads/WARP/{FEATURE}. Example: refs/heads/WARP/P3C-SIGNAL-FOLLOWING"
                  },
                  "sha": {
                    "type": "string",
                    "description": "Latest main SHA from getRepoBranch"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Branch created"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/git/refs/heads/{branch}": {
      "get": {
        "operationId": "getRepoBranch",
        "summary": "Get branch info including latest commit SHA",
        "description": "Use to get latest commit SHA before creating a new branch. Path uses plural 'refs'.",
        "parameters": [
          {
            "name": "branch",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Branch name. Example: main"
          }
        ],
        "responses": {
          "200": {
            "description": "Branch info — object.sha is the latest commit SHA"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues": {
      "get": {
        "operationId": "listIssues",
        "summary": "List issues in walkermind-os",
        "description": "Filter by label: agent:forge, agent:sentinel, major, standard, minor, gate-dispatched.",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "closed",
                "all"
              ],
              "default": "open"
            }
          },
          {
            "name": "labels",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated. Example: agent:forge,major"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of issues"
          }
        }
      },
      "post": {
        "operationId": "createIssue",
        "summary": "Create issue in walkermind-os",
        "description": "Use for FORGE tasks and SENTINEL tasks. Body: WARP TASK template from COMMANDER.md. Labels: agent:forge, agent:sentinel, major/standard/minor, gate-dispatched.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Example: [GATE] P3c — SignalFollowingStrategy"
                  },
                  "body": {
                    "type": "string"
                  },
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Example: [\"agent:forge\",\"major\",\"gate-dispatched\"]"
                  },
                  "assignees": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Example: [\"bayuewalker\"]"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Issue created — returns number and html_url"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}": {
      "get": {
        "operationId": "getIssue",
        "summary": "Get single issue by number",
        "description": "Returns title, body, labels, state, assignees.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Full issue object"
          }
        }
      },
      "patch": {
        "operationId": "updateIssue",
        "summary": "Update or close an issue",
        "description": "To close: state='closed', state_reason='completed' or 'not_planned'. To reopen: state='open'.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "state": {
                    "type": "string",
                    "enum": [
                      "open",
                      "closed"
                    ]
                  },
                  "title": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string"
                  },
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "state_reason": {
                    "type": "string",
                    "enum": [
                      "completed",
                      "not_planned",
                      "reopened"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Issue updated"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}/comments": {
      "post": {
        "operationId": "addIssueComment",
        "summary": "Add comment to issue or PR",
        "description": "GitHub uses issues endpoint for PR comments too. Use for GATE findings, FORGE task dispatch, SENTINEL verdict.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "body"
                ],
                "properties": {
                  "body": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Comment added"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}/labels": {
      "post": {
        "operationId": "addIssueLabel",
        "summary": "Add labels to issue or PR",
        "description": "Valid labels: agent:forge, agent:sentinel, major, standard, minor, gate-dispatched, needs-fix, ready-for-merge, on-hold.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "labels"
                ],
                "properties": {
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Labels added"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}/labels/{name}": {
      "delete": {
        "operationId": "removeIssueLabel",
        "summary": "Remove a label from issue or PR",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Remaining labels"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}/assignees": {
      "post": {
        "operationId": "addAssignees",
        "summary": "Add assignees to issue or PR",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "assignees"
                ],
                "properties": {
                  "assignees": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Example: [\"bayuewalker\"]"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Assignees added"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/labels": {
      "get": {
        "operationId": "listRepoLabels",
        "summary": "List all labels in walkermind-os",
        "description": "Verify label names before applying. Active labels: agent:forge, agent:sentinel, major, standard, minor, gate-dispatched.",
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of labels"
          }
        }
      }
    },
    "/repos/bayuewalker/warp-codx/issues": {
      "get": {
        "operationId": "listWarpCodxIssues",
        "summary": "List issues in warp-codx",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "closed",
                "all"
              ],
              "default": "open"
            }
          },
          {
            "name": "labels",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of issues"
          }
        }
      },
      "post": {
        "operationId": "createWarpCodxIssue",
        "summary": "Create issue in warp-codx",
        "description": "For FORGE/SENTINEL tasks scoped to warp-codx.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string"
                  },
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "assignees": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Issue created"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls": {
      "get": {
        "operationId": "listPullRequests",
        "summary": "List PRs in walkermind-os",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "closed",
                "all"
              ],
              "default": "open"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of PRs"
          }
        }
      },
      "post": {
        "operationId": "createPullRequest",
        "summary": "Create a pull request in walkermind-os",
        "description": "Open PR from WARP/* branch to main. Include tier, claim level, closes #issue in body.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "head",
                  "base"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "head": {
                    "type": "string",
                    "description": "Source branch. Example: WARP/CRUSADERBOT-P3C-SIGNAL-FOLLOWING"
                  },
                  "base": {
                    "type": "string",
                    "description": "Always: main"
                  },
                  "body": {
                    "type": "string",
                    "description": "Include: tier, claim level, scope, report path, closes #issue"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "PR created"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}": {
      "get": {
        "operationId": "getPullRequest",
        "summary": "Get single PR by number",
        "description": "Returns: number, title, body, state, head.sha, head.ref, mergeable, mergeable_state, merged, merged_at.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Full PR object"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}/merge": {
      "put": {
        "operationId": "mergePullRequest",
        "summary": "Merge a PR (squash only)",
        "description": "FORGE and SENTINEL never call this. CMD auto-merges MINOR/STANDARD. MAJOR requires Mr. Walker explicit go. Always include sha (expected_head_sha) to prevent race condition.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "commit_title": {
                    "type": "string"
                  },
                  "commit_message": {
                    "type": "string"
                  },
                  "sha": {
                    "type": "string",
                    "description": "REQUIRED: expected_head_sha from getPullRequest.head.sha. Prevents race condition."
                  },
                  "merge_method": {
                    "type": "string",
                    "enum": [
                      "squash"
                    ],
                    "default": "squash"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Merged — returns sha"
          },
          "405": {
            "description": "Not mergeable"
          },
          "409": {
            "description": "SHA mismatch — re-fetch and retry"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}/update-branch": {
      "put": {
        "operationId": "updatePRBranch",
        "summary": "Rebase PR branch onto latest main",
        "description": "Use when mergeable_state='dirty' or 'behind'. Required before merge if branch is out of date.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "expected_head_sha": {
                    "type": "string",
                    "description": "Current head SHA of PR branch"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Branch update accepted"
          },
          "422": {
            "description": "Merge conflict — cannot auto-rebase"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}/files": {
      "get": {
        "operationId": "getPRFiles",
        "summary": "Get files changed in a PR",
        "description": "Returns each file: filename, status (added/modified/removed/renamed), additions, deletions, patch diff. Use for scope hygiene check.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of changed files"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}/reviews": {
      "get": {
        "operationId": "getPRReviews",
        "summary": "Get all review results for a PR",
        "description": "Returns reviews: reviewer name, state (APPROVED/CHANGES_REQUESTED/COMMENTED), body. Check before merge — CHANGES_REQUESTED blocks merge.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of reviews"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls/{pull_number}/comments": {
      "get": {
        "operationId": "getPRInlineComments",
        "summary": "Get inline diff comments on a PR",
        "description": "Inline comments attached to specific file lines. Use to read bot/reviewer feedback on code.",
        "parameters": [
          {
            "name": "pull_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of inline comments with path, line, body, user"
          }
        }
      }
    },
