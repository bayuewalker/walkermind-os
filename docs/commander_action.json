{
  "openapi": "3.1.0",
  "info": {
    "title": "WARP⛳CMD — GitHub Full Access",
    "description": "Full read/write/review access to walkermind-os AND warp-codx repos. Read files, write files, manage branches, create and merge PRs, fetch PR details and file diffs, manage issues and labels. walkermind-os: bayuewalker/walkermind-os. warp-codx: bayuewalker/warp-codx.",
    "version": "3.2.0"
  },
  "servers": [
    {
      "url": "https://api.github.com"
    }
  ],
  "paths": {
    "/repos/bayuewalker/walkermind-os/contents/{path}": {
      "get": {
        "operationId": "getRepoContents",
        "summary": "Read file or list directory from walkermind-os repo",
        "description": "If path is a file, returns base64-encoded content. If path is a directory, returns array of files. Use for AGENTS.md, PROJECT_STATE.md, reports/forge/, reports/sentinel/, docs/, etc.",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "File or directory path from repo root. Example: AGENTS.md | projects/polymarket/crusaderbot/state/PROJECT_STATE.md"
          },
          {
            "name": "ref",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Branch name. Default: main"
          }
        ],
        "responses": {
          "200": {
            "description": "File content (base64) or directory listing (array)"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "operationId": "writeRepoFile",
        "summary": "Create or update a file in walkermind-os repo",
        "description": "Creates a new file or updates existing file. Content must be base64-encoded. Requires sha when updating existing file.",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "message",
                  "content"
                ],
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "Commit message. Example: gate: post-merge sync [warp-gate[bot]]"
                  },
                  "content": {
                    "type": "string",
                    "description": "Base64-encoded file content"
                  },
                  "sha": {
                    "type": "string",
                    "description": "Required when UPDATING existing file. Get SHA from getRepoContents first."
                  },
                  "branch": {
                    "type": "string",
                    "description": "Target branch. Default: main"
                  },
                  "author": {
                    "type": "object",
                    "description": "Commit author. Always use: {name: 'warp-gate[bot]', email: 'warp-gate[bot]@users.noreply.github.com'}"
                  },
                  "committer": {
                    "type": "object",
                    "description": "Committer identity. Mirror author field."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File updated"
          },
          "201": {
            "description": "File created"
          }
        }
      }
    },
    "/repos/bayuewalker/warp-codx/contents/{path}": {
      "get": {
        "operationId": "getWarpCodxContents",
        "summary": "Read file or list directory from warp-codx repo",
        "description": "Same as getRepoContents but for warp-codx repo. Use for CHANGELOG.md, docs/, src/ in warp-codx.",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "File path from warp-codx repo root. Example: CHANGELOG.md | docs/COMMANDER.md"
          },
          {
            "name": "ref",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Branch name. Default: main"
          }
        ],
        "responses": {
          "200": {
            "description": "File content (base64) or directory listing"
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "operationId": "writeWarpCodxFile",
        "summary": "Create or update a file in warp-codx repo",
        "description": "Creates or updates a file in warp-codx. Content must be base64-encoded.",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "message",
                  "content"
                ],
                "properties": {
                  "message": {
                    "type": "string"
                  },
                  "content": {
                    "type": "string",
                    "description": "Base64-encoded content"
                  },
                  "sha": {
                    "type": "string",
                    "description": "Required when updating. Get from getWarpCodxContents."
                  },
                  "branch": {
                    "type": "string",
                    "description": "Default: main"
                  },
                  "author": {
                    "type": "object",
                    "description": "Always use warp-gate[bot] identity"
                  },
                  "committer": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "File updated"
          },
          "201": {
            "description": "File created"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/git/refs": {
      "post": {
        "operationId": "createBranch",
        "summary": "Create a new branch in walkermind-os repo",
        "description": "Creates a new branch from a base SHA. Always use WARP/{FEATURE} uppercase hyphen format per AGENTS.md.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "ref",
                  "sha"
                ],
                "properties": {
                  "ref": {
                    "type": "string",
                    "description": "New branch ref. Format: refs/heads/WARP/{FEATURE-SLUG}. Example: refs/heads/WARP/P3C-SIGNAL-FOLLOWING"
                  },
                  "sha": {
                    "type": "string",
                    "description": "SHA of base commit (latest main). Get from getRepoBranch."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Branch created"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/git/refs/heads/{branch}": {
      "get": {
        "operationId": "getRepoBranch",
        "summary": "Get branch info including latest commit SHA",
        "description": "Use to get the latest commit SHA before creating a new branch. Note: path uses plural 'refs'.",
        "parameters": [
          {
            "name": "branch",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Branch name. Example: main"
          }
        ],
        "responses": {
          "200": {
            "description": "Branch info with object.sha (latest commit SHA)"
          }
        }
      },
      "delete": {
        "operationId": "deleteBranch",
        "summary": "Delete a branch after merge",
        "description": "Deletes a branch ref. Use after PR is merged. Never delete main.",
        "parameters": [
          {
            "name": "branch",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Branch name. Example: WARP/FIX-SIGNAL-FILTER"
          }
        ],
        "responses": {
          "204": {
            "description": "Branch deleted"
          },
          "422": {
            "description": "Branch cannot be deleted"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/branches": {
      "get": {
        "operationId": "listBranches",
        "summary": "List all branches in walkermind-os repo",
        "description": "Returns all branches. Use to check open WARP/* branches and verify no orphaned branches post-merge.",
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of branches with name and commit SHA"
          }
        }
      }
    },
    "/repos/bayuewalker/warp-codx/pulls": {
      "get": {
        "operationId": "listWarpCodxPullRequests",
        "summary": "List pull requests in warp-codx repo",
        "description": "Returns open or all PRs in warp-codx. Use to check WARP/* PR status alongside walkermind-os PRs.",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "closed",
                "all"
              ],
              "default": "open"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of pull requests"
          }
        }
      }
    },
    "/repos/bayuewalker/warp-codx/issues": {
      "get": {
        "operationId": "listWarpCodxIssues",
        "summary": "List issues in warp-codx repo",
        "description": "Returns open or all issues in warp-codx.",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "closed",
                "all"
              ],
              "default": "open"
            }
          },
          {
            "name": "labels",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of issues"
          }
        }
      },
      "post": {
        "operationId": "createWarpCodxIssue",
        "summary": "Create a new issue in warp-codx repo",
        "description": "Creates a GitHub issue in warp-codx. Use for FORGE tasks, SENTINEL tasks scoped to warp-codx.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string"
                  },
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Label names. Use: agent:forge, agent:sentinel, major, standard, minor, gate-dispatched"
                  },
                  "assignees": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "GitHub usernames. Example: [\"bayuewalker\"]"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Issue created"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues": {
      "get": {
        "operationId": "listIssues",
        "summary": "List issues in walkermind-os repo",
        "description": "Returns open or all issues. Filter by label to get only agent:forge or agent:sentinel issues.",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "closed",
                "all"
              ],
              "default": "open"
            }
          },
          {
            "name": "labels",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Comma-separated. Example: agent:forge,major"
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of issues with number, title, labels, state"
          }
        }
      },
      "post": {
        "operationId": "createIssue",
        "summary": "Create a new issue in walkermind-os repo",
        "description": "Creates a GitHub issue. Use to create WARP•FORGE tasks, WARP•SENTINEL tasks, or tracked work items. Body should follow WARP•FORGE TASK template from COMMANDER.md.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Example: [GATE] P3c — SignalFollowingStrategy implementation"
                  },
                  "body": {
                    "type": "string",
                    "description": "Issue body. Use WARP•FORGE TASK template from COMMANDER.md."
                  },
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Label names. Use actual taxonomy: agent:forge, agent:sentinel, major, standard, minor, gate-dispatched"
                  },
                  "assignees": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "GitHub usernames. Example: [\"bayuewalker\"]"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Issue created — returns number and URL"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}": {
      "get": {
        "operationId": "getIssue",
        "summary": "Get a single issue by number",
        "description": "Returns full issue details: title, body, labels, state, assignees, comments count.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Full issue object"
          }
        }
      },
      "patch": {
        "operationId": "updateIssue",
        "summary": "Update or close an issue",
        "description": "Update state, title, body, labels. To CLOSE: set state to 'closed' + state_reason to 'completed' or 'not_planned'.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "state": {
                    "type": "string",
                    "enum": [
                      "open",
                      "closed"
                    ]
                  },
                  "title": {
                    "type": "string"
                  },
                  "body": {
                    "type": "string"
                  },
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "state_reason": {
                    "type": "string",
                    "enum": [
                      "completed",
                      "not_planned",
                      "reopened"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Issue updated"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}/comments": {
      "post": {
        "operationId": "addIssueComment",
        "summary": "Add a comment to an issue or PR",
        "description": "Adds a comment. For PRs use PR number (GitHub uses issues endpoint for PR comments too). Use to post SENTINEL verdict, FORGE task, or GATE findings.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "body"
                ],
                "properties": {
                  "body": {
                    "type": "string",
                    "description": "Comment text. Markdown supported."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Comment added"
          }
        }
      },
      "get": {
        "operationId": "getIssueComments",
        "summary": "Get all comments on an issue or PR",
        "description": "Returns all comments. Use to read full review context before gate decision.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of comments with user, body, created_at"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}/labels": {
      "post": {
        "operationId": "addIssueLabel",
        "summary": "Add labels to an issue or PR",
        "description": "Add labels. Valid taxonomy: agent:forge, agent:sentinel, major, standard, minor, gate-dispatched, needs-fix, ready-for-merge, on-hold.",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "labels"
                ],
                "properties": {
                  "labels": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Labels added"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}/labels/{name}": {
      "delete": {
        "operationId": "removeIssueLabel",
        "summary": "Remove a specific label from an issue or PR",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Label name to remove. Example: agent:sentinel"
          }
        ],
        "responses": {
          "200": {
            "description": "Remaining labels"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/issues/{issue_number}/assignees": {
      "post": {
        "operationId": "addAssignees",
        "summary": "Add assignees to an issue or PR",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "assignees"
                ],
                "properties": {
                  "assignees": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "GitHub usernames. Example: [\"bayuewalker\"]"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Assignees added"
          }
        }
      },
      "delete": {
        "operationId": "removeAssignees",
        "summary": "Remove assignees from an issue or PR",
        "parameters": [
          {
            "name": "issue_number",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "assignees"
                ],
                "properties": {
                  "assignees": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Assignees removed"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/labels": {
      "get": {
        "operationId": "listRepoLabels",
        "summary": "List all labels in walkermind-os repo",
        "description": "Returns all available labels. Use to verify label names before applying.",
        "parameters": [
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of labels with name, color, description"
          }
        }
      },
      "post": {
        "operationId": "createRepoLabel",
        "summary": "Create a new label in walkermind-os repo",
        "description": "Creates a label. Standard WARP labels: agent:forge, agent:sentinel, major, standard, minor, gate-dispatched, needs-fix, ready-for-merge, on-hold.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name"
                ],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "color": {
                    "type": "string",
                    "description": "Hex without #. Example: e4e669 (yellow), d93f0b (red), 0075ca (blue)"
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Label created"
          }
        }
      }
    },
    "/repos/bayuewalker/walkermind-os/pulls": {
      "get": {
        "operationId": "listPullRequests",
        "summary": "List pull requests in walkermind-os repo",
        "parameters": [
          {
            "name": "state",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "open",
                "closed",
                "all"
              ],
              "default": "open"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of pull requests"
          }
        }
      },
      "post": {
        "operationId": "createPullRequest",
        "summary": "Create a pull request",
        "description": "Opens a new PR from a WARP/* branch to main. Include task summary, files changed, report path, validation tier, claim level in body.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "head",
                  "base"
                ],
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Example: feat(crusaderbot): P3c signal-following strategy (#issue)"
                  },
                  "head": {
                    "type": "string",
                    "description": "Source branch. Example: WARP/CRUSADERBOT-P3C-SIGNAL-FOLLOWING"
                  },
                  "base": {
                    "type": "string",
                    "description": "Target branch. Always: main"
                  },
                  "body": {
                    "type": "string",
                    "description": "PR description. Include: scope, files changed, report path, validation tier, claim level, closes #issue."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "PR created"
