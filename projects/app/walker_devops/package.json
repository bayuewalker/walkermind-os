{
  "name": "walker-devops",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:frontend\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "build": "npm run build:server && npm run build:frontend",
    "build:server": "tsc -p tsconfig.server.json",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "test": "vitest run",
    "verify:stream": "tsx scripts/verify-stream.ts"
  },
  "dependencies": {
    "@openai/agents": "^0.1.6",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.17",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^5.4.18",
    "vitest": "^2.1.9"
  }
}
