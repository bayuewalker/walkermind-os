# Phase 7 — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Polymarket CLOB Credentials ───────────────────────────────────────────────
CLOB_API_KEY=your_api_key_here
CLOB_API_SECRET=your_api_secret_here
CLOB_API_PASSPHRASE=your_passphrase_here
CLOB_CHAIN_ID=137

# ── WebSocket ─────────────────────────────────────────────────────────────────
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ── Execution Mode ────────────────────────────────────────────────────────────
# Set to "true" to run in paper mode (no real orders placed)
DRY_RUN=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
