# CrusaderBot environment template.
# Copy to .env, fill in real values. NEVER commit .env to git.

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
OPERATOR_CHAT_ID=your_telegram_numeric_id

# Postgres + Redis
DATABASE_URL=postgresql+asyncpg://user:pass@host/crusaderbot
REDIS_URL=redis://localhost:6379

# Polygon / wallet plane
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key
ALCHEMY_POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your_key
ALCHEMY_POLYGON_WS_URL=wss://polygon-mainnet.g.alchemy.com/v2/your_key
USDC_POLYGON=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
# Native (non-bridged) USDC on Polygon — used by the R4 deposit watcher.
USDC_CONTRACT_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
MASTER_WALLET_ADDRESS=0x...
MASTER_WALLET_PRIVATE_KEY=0x...
WALLET_HD_SEED=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12
WALLET_ENCRYPTION_KEY=your_fernet_key_here

# Heisenberg / Falcon API — market data + signal enrichment
# Token set via: fly secrets set HEISENBERG_API_TOKEN=<token>
HEISENBERG_API_TOKEN=your_token_here

# Polymarket CLOB (paper-mode tolerates empty values; live mode requires real)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# Telegram webhook mode (leave unset for polling). Set BOTH together.
# Generate the secret: openssl rand -hex 32
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# WebTrader browser dashboard — disabled when unset.
# Generate: openssl rand -hex 32
# Fly: fly secrets set WEBTRADER_JWT_SECRET=<value> --app crusaderbot
WEBTRADER_JWT_SECRET=

# /ops dashboard kill/resume shared secret — mutators 503 when unset.
# Generate: openssl rand -hex 32
OPS_SECRET=

# Admin REST API bearer token (hardened /admin/* path) — disabled when unset.
# Generate: openssl rand -hex 32
ADMIN_API_TOKEN=

# Optional error tracking. Leave unset to no-op Sentry.
SENTRY_DSN=

# Activation guards — all default OFF. Flip only via explicit deploy decision.
# RISK_CONTROLS_VALIDATED requires a WARP•SENTINEL PASS report first.
ENABLE_LIVE_TRADING=false
EXECUTION_PATH_VALIDATED=false
CAPITAL_MODE_CONFIRMED=false
RISK_CONTROLS_VALIDATED=false
USE_REAL_CLOB=false
FEE_COLLECTION_ENABLED=false
AUTO_REDEEM_ENABLED=false

# Operational
APP_ENV=development
MIN_DEPOSIT_USDC=50
MARKET_SCAN_INTERVAL=300
DEPOSIT_WATCH_INTERVAL=120
DB_POOL_MAX=5
